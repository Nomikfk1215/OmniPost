OMNIPOST_USE_LLM=false
OPENAI_API_KEY=
OMNIPOST_OPENAI_BASE_URL=https://api.openai.com/v1
OMNIPOST_OPENAI_MODEL=gpt-4o-mini
OMNIPOST_ENCRYPTION_KEY=replace-with-a-long-random-secret
OMNIPOST_OAUTH_STATE_SECRET=replace-with-another-long-random-secret

# Optional: Bilibili Open Platform web app. Without these, Bilibili uses assist publish.
# Request the ATC_BASE scope if you want real article publishing.
OMNIPOST_BILIBILI_CLIENT_ID=
OMNIPOST_BILIBILI_CLIENT_SECRET=
OMNIPOST_BILIBILI_DEFAULT_CATEGORY=1

# Xiaohongshu service-provider app. OAuth can connect accounts; note publishing stays assist-only until permissions are approved.
OMNIPOST_XIAOHONGSHU_APP_ID=
OMNIPOST_XIAOHONGSHU_APP_SECRET=
